# Frontend (Next.js / Vercel)
# Copy to .env.local for local development.

# Public site URL (sitemap, absolute links)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# FastAPI backend URL (Railway) — required in production
# Must be the full origin; https:// is added automatically if omitted
# Local dev: http://127.0.0.1:8090
NEXT_PUBLIC_AI_API_URL=https://your-backend.up.railway.app

# Beta mode — set to false to re-enable traditional portfolio routes and avatar intro
NEXT_PUBLIC_BETA_MODE=true
# Optional server-only override (runtime on Vercel, no rebuild required)
# BETA_MODE=true

# Optional — only if adding client-side Supabase features later
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — voice features (not required for chat)
# ELEVENLABS_API_KEY=
