# Backend (FastAPI / Render)
# Copy to backend/.env for local development.

APP_NAME=Lakshay.ai API
APP_ENV=production
DEBUG=false

# LLM provider: gemini | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=60

# Comma-separated allowed browser origins (Vercel frontend URL)
CORS_ORIGINS=https://your-domain.vercel.app,http://localhost:3000

# Supabase analytics — required in production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
