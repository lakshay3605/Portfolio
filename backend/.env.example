# Backend (FastAPI / Railway)
# Copy to backend/.env for local development.

APP_NAME=Lakshay.ai API
APP_ENV=production
DEBUG=false

# LLM provider: gemini | groq
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (only if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=60

# Comma-separated allowed browser origins (Vercel frontend URL)
CORS_ORIGINS=https://your-domain.vercel.app,http://localhost:3000

# Supabase analytics — required in production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
